# GitHub Integration Configuration
# These environment variables configure the GitHub API integration for fetching repository data

# GitHub username - The GitHub username whose repositories will be fetched
# Required for GitHub integration to work
# Example: GITHUB_USERNAME=octocat
GITHUB_USERNAME=

# GitHub personal access token - Used for authenticated API requests
# Optional but recommended to increase rate limits (5000 requests/hour vs 60 requests/hour)
# Create a token at: https://github.com/settings/tokens
# Required scopes: public_repo (or repo for private repositories)
# Example: GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_TOKEN=

# GitHub data revalidation time in seconds
# Controls how often Next.js refetches data from GitHub API
# Default: 3600 (1 hour)
# Set to 0 to disable caching (not recommended)
# Example: GITHUB_REVALIDATE=3600
GITHUB_REVALIDATE=3600

# GitHub repository filter - Comma-separated list of repository names to display
# Optional: If not set, all public repositories will be fetched
# Use this to control which repositories appear on your portfolio
# Example: GITHUB_REPOSITORIES=my-awesome-project,another-cool-repo,portfolio-website
GITHUB_REPOSITORIES=
